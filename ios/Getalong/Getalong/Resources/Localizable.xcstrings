    "auth.hero.title.line1" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Find someone you" }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "気が合う人と、" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "找到一個" }}
    }},
    "auth.hero.title.line2" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "just get along with." }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "自然につながる。" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "與你合拍的人。" }}
    }},
    "auth.hero.subtitle" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Start with a small signal. If it clicks, talk live." }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ふとした一言から。合いそうなら、そのまま会話へ。" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "從一個小訊號開始。合得來，就開始對話。" }}
    }},
    "auth.hero.teaser.label" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "SIGNAL" }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "きっかけ" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時訊號" }}
    }},
    "auth.hero.teaser.message" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "I get along best with people who don’t take life too seriously." }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "気を張らずに話せる人と出会いたい。" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "想認識可以自然聊下去的人。" }}
    }},
    "auth.hero.teaser.live" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Live" }},
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "ライブ" }},
      "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時" }}
    }},
